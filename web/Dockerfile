FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm install --legacy-peer-deps
COPY . .

ARG USER_SERVICE_URL=http://user-service:8001
ARG PRODUCT_SERVICE_URL=http://product-service:8002
ARG CART_SERVICE_URL=http://cart-service:8003
ARG ORDER_SERVICE_URL=http://order-service:8004
ARG PAYMENT_SERVICE_URL=http://payment-service:8005
ARG REVIEW_SERVICE_URL=http://review-service:8006
ARG SELLER_SERVICE_URL=http://seller-service:8007
ARG NOTIFICATION_SERVICE_URL=http://notification-service:8008
ARG SEARCH_SERVICE_URL=http://search-service:8009
ARG RECOMMENDATION_SERVICE_URL=http://recommendation-service:8010
ARG REFERRAL_SERVICE_URL=http://referral-service:8012
ARG DELIVERY_SERVICE_URL=http://delivery-service:8013
ARG ANALYTICS_SERVICE_URL=http://analytics-service:8014

ENV USER_SERVICE_URL=$USER_SERVICE_URL
ENV PRODUCT_SERVICE_URL=$PRODUCT_SERVICE_URL
ENV CART_SERVICE_URL=$CART_SERVICE_URL
ENV ORDER_SERVICE_URL=$ORDER_SERVICE_URL
ENV PAYMENT_SERVICE_URL=$PAYMENT_SERVICE_URL
ENV REVIEW_SERVICE_URL=$REVIEW_SERVICE_URL
ENV SELLER_SERVICE_URL=$SELLER_SERVICE_URL
ENV NOTIFICATION_SERVICE_URL=$NOTIFICATION_SERVICE_URL
ENV SEARCH_SERVICE_URL=$SEARCH_SERVICE_URL
ENV RECOMMENDATION_SERVICE_URL=$RECOMMENDATION_SERVICE_URL
ENV REFERRAL_SERVICE_URL=$REFERRAL_SERVICE_URL
ENV DELIVERY_SERVICE_URL=$DELIVERY_SERVICE_URL
ENV ANALYTICS_SERVICE_URL=$ANALYTICS_SERVICE_URL

RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV production
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/package*.json ./
COPY --from=builder /app/next.config.js ./
RUN npm install --omit=dev --legacy-peer-deps
EXPOSE 3000
CMD ["npm", "start"]

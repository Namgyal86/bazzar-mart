# ============================================================
# Bazzar Web — Local Environment
# Copy to .env.local:  cp .env.local.example .env.local
#
# SINGLE BASE URL:
#   The frontend now talks to ONE backend.
#   In development, Next.js rewrites proxy all /api/v1/* calls
#   to MONOLITH_URL — you do NOT need NEXT_PUBLIC_API_BASE_URL.
#   In production, set NEXT_PUBLIC_API_BASE_URL to your CDN/ALB URL.
# ============================================================

# ── Backend (server-side rewrites, never exposed to the browser) ──────────────
MONOLITH_URL=http://localhost:8100
DELIVERY_SERVICE_URL=http://localhost:8013
NOTIFICATION_SERVICE_URL=http://localhost:8008

# ── Browser-visible API URL (leave empty in dev → proxied through Next.js) ────
# Set this in production: NEXT_PUBLIC_API_BASE_URL=https://api.bazzar.com
NEXT_PUBLIC_API_BASE_URL=

# ── WebSocket (delivery tracking) ─────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:8013

# ── Health endpoint token (optional — protect /health/db and /health/full) ────
# HEALTH_TOKEN=your-random-token-here

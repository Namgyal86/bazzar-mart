# ── Notifications ─────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SPARROW_SMS_TOKEN=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── AWS S3 (product images) ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
CLOUDFRONT_URL=

# ── Monolith URL (replaces all individual service URLs) ───────────────────────
# MONOLITH_URL is used by the Next.js web server for server-side rewrites.
# Clients use NEXT_PUBLIC_API_BASE_URL (empty = proxied through Next.js rewrites).
MONOLITH_URL=http://localhost:8100
NEXT_PUBLIC_API_BASE_URL=

# ── Web/API URLs (used by payment gateway callbacks) ──────────────────────────
WEB_URL=http://localhost:3000
API_BASE_URL=http://localhost:8100

# ── Kept-separate services ────────────────────────────────────────────────────
DELIVERY_SERVICE_URL=http://localhost:8013
NOTIFICATION_SERVICE_URL=http://localhost:8008



# ============================================================
#  Bazzar API Monolith — Master Environment File
#  Copy to .env and fill in real values before running.
# ============================================================

# -- Server --
NODE_ENV=development
PORT=8100

# -- Auth --
JWT_ACCESS_SECRET=access_secret_dev
JWT_REFRESH_SECRET=refresh_secret_dev

# -- MongoDB (single connection, all modules share one DB) --
MONGO_URI=mongodb://localhost:27017/bazzar_monolith

# -- Redis (cart module) --
REDIS_URL=redis://localhost:6379

# -- Kafka --
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=api-monolith
KAFKA_GROUP_ID=api-monolith-group

# -- Payment Gateways --
KHALTI_SECRET_KEY=your_khalti_secret_key
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q(
ESEWA_MERCHANT_CODE=EPAYTEST
FONEPAY_MERCHANT_CODE=your_fonepay_merchant_code
FONEPAY_SECRET_KEY=your_fonepay_secret_key

# -- URLs --
# Used by payment gateway callbacks
API_BASE_URL=http://localhost:8100
WEB_URL=http://localhost:3000

# -- External kept microservices (for Kafka-based communication) --
# These services consume Kafka events published by this monolith.
# No direct HTTP calls to these services from within the monolith.
# NOTIFICATION_SERVICE_URL is no longer needed (replaced by Kafka).

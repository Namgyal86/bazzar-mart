# ============================================================
#  Bazzar API Monolith — Master Environment File
#  Copy to .env and fill in real values before running.
# ============================================================

# -- Server --
NODE_ENV=development
PORT=8100

# -- Auth (min 32 chars each — use a strong random value in production) --
JWT_ACCESS_SECRET=dev_access_secret_must_be_32_chars_min
JWT_REFRESH_SECRET=dev_refresh_secret_must_be_32_chars_min
HEALTH_TOKEN=

# -- MongoDB (single connection, all modules share one DB) --
MONGO_URI=mongodb://bazzar-mongodb:27017/

# -- Redis (cart module) --
REDIS_URL=redis://bazzar-redis:6379

# -- Kafka --
KAFKA_BROKERS=bazzar-kafka:9092
KAFKA_CLIENT_ID=api-monolith
KAFKA_GROUP_ID=api-monolith-group

# -- Payment Gateways --
KHALTI_SECRET_KEY=your_khalti_secret_key
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q(
ESEWA_MERCHANT_CODE=EPAYTEST
FONEPAY_MERCHANT_CODE=your_fonepay_merchant_code
FONEPAY_SECRET_KEY=your_fonepay_secret_key

# -- URLs --
# Used by payment gateway callbacks
API_BASE_URL=http://localhost:8100
WEB_URL=http://localhost:3000

# -- External kept microservices (for Kafka-based communication) --
# These services consume Kafka events published by this monolith.
# No direct HTTP calls to these services from within the monolith.
# NOTIFICATION_SERVICE_URL is no longer needed (replaced by Kafka).

# -- OAuth (Google & Facebook login) --
# Google: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:8100/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook: https://developers.facebook.com → your app → Facebook Login → Settings
# Authorized redirect URI: http://localhost:8100/api/v1/auth/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
